                "type": "Spoofing",
                "modelType": "STRIDE",
                "severity": "High",
                "status": "Open",
                "score": "",
                "description": "La API expone endpoints sensibles sin autenticación ni autorización, permitiendo que un atacante se haga pasar por un usuario legítimo.",
                "mitigation": "Incorporar autenticación/autorización, control de acceso por endpoint y validación de identidad."
              },
