                "modelType": "STRIDE",
                "severity": "High",
                "status": "Open",
                "score": "",
                "description": "El uso de shell=True permite inyección de comandos y elevación de privilegios sobre el host.",
                "mitigation": "Eliminar shell=True, usar listas seguras de argumentos y ejecutar con privilegios mínimos."
              },
