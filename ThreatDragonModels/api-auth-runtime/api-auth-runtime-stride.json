                "modelType": "STRIDE",
                "severity": "High",
                "status": "Open",
                "score": "",
                "description": "La construcción dinámica de consultas SQL permite alterar la consulta mediante entrada manipulada.",
                "mitigation": "Usar consultas parametrizadas, validación de entrada y reglas SAST."
              },
              {
                "threatId": "03442d03-6eda-4961-8ac4-0875d441e3cc",
