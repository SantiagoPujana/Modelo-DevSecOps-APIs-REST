            "data": {
              "name": "api-auth\n(FastAPI)",
              "description": "Servicio REST vulnerable usado en la simulación DevSecOps.",
              "type": "tm.Process",
              "isTrustBoundary": false,
              "outOfScope": false,
              "reasonOutOfScope": "",
              "threats": [
                {
                  "ruleId": "3f0a2f87-1c1e-48f2-a5cd-66687a5a6fb1",
                  "title": "Acceso sin autenticación fuerte",
                  "type": "Spoofing",
                  "modelType": "STRIDE",
                  "status": "Open",
                  "severity": "High",
                  "description": "Los endpoints sensibles pueden ser invocados sin autenticación ni autorización robusta.",
                  "mitigation": "Implementar autenticación, autorización por endpoint, validación de identidad y pruebas negativas.",
                  "threatId": "3cd9ba03-3d90-43cc-8457-95813d5b767a",
                  "id": "439aeb00-6e3d-4d6b-a899-4e982c09908d"
                },
                {
                  "ruleId": "f1bce193-b524-42e2-8be9-119f4c92d660",
                  "title": "SQL Injection en /user",
                  "type": "Tampering",
                  "modelType": "STRIDE",
                  "status": "Open",
                  "severity": "High",
                  "description": "El parámetro username puede alterar la consulta SQL construida por concatenación.",
                  "mitigation": "Usar consultas parametrizadas, validación de entrada y reglas SAST/DAST para inyección.",
                  "threatId": "e05b1f45-0991-42fb-924f-15d59770de8b",
                  "id": "acb0e098-ad27-442c-ab8c-cc354744d730"
                },
                {
                  "ruleId": "6370cdb1-d766-4e63-bc61-4b45387d94cc",
                  "title": "Command Injection en /exec",
                  "type": "Elevation of privilege",
                  "modelType": "STRIDE",
                  "status": "Open",
                  "severity": "High",
                  "description": "El uso de shell=True permite ejecutar comandos arbitrarios en el contenedor.",
                  "mitigation": "Eliminar shell=True, validar argumentos y ejecutar con privilegios mínimos.",
                  "threatId": "07fea713-283e-492d-98d9-04b00316ce98",
                  "id": "3e37f768-3e7c-40c6-8da4-63440fb193f7"
                },
                {
                  "ruleId": "01829ef9-9eca-4364-85a0-cf39c9ad5237",
                  "title": "Deserialización insegura en /pickle",
                  "type": "Elevation of privilege",
                  "modelType": "STRIDE",
                  "status": "Open",
                  "severity": "High",
                  "description": "pickle.loads sobre entrada no confiable puede ejecutar código arbitrario.",
                  "mitigation": "Eliminar pickle para datos externos y usar formatos seguros como JSON.",
                  "threatId": "d141bab7-461d-42bc-9ce2-e8929ed8dc55",
                  "id": "57b59ba9-2571-49e4-b817-9a35aacc9dff"
                },
                {
                  "ruleId": "d1e5ea25-6b2e-4f47-b38d-968b8d251a37",
                  "title": "Secreto embebido y MD5",
                  "type": "Information disclosure",
                  "modelType": "STRIDE",
                  "status": "Open",
                  "severity": "Medium",
                  "description": "El código contiene SECRET_KEY hardcodeada y usa MD5 para hash.",
                  "mitigation": "Mover secretos a variables seguras y usar algoritmos robustos.",
                  "threatId": "0b194874-336a-47fa-91d6-811f90760aeb",
                  "id": "16ec9747-1f52-41fc-a3ec-8a8d1b8fcffa"
                },
                {
                  "ruleId": "a0560484-b8a4-4ba6-ba8c-b990be5900f6",
                  "title": "Falta de trazabilidad de endpoints críticos",
                  "type": "Repudiation",
                  "modelType": "STRIDE",
                  "status": "Open",
                  "severity": "Medium",
                  "description": "Las llamadas críticas no quedan asociadas a una identidad ni auditoría suficiente.",
                  "mitigation": "Agregar logs/auditoría mínima, request-id y evidencias de pruebas.",
                  "threatId": "6dbe2c4c-acb9-4d46-bcfc-8892ae2bfcf9",
                  "id": "b2ba5a9f-3bf4-4332-850a-773c9670a462"
                },
                {
                  "ruleId": "04f3622f-d389-4a92-aad6-b2d1a700fc17",
                  "title": "Abuso de endpoints expuestos",
                  "type": "Denial of service",
                  "modelType": "STRIDE",
                  "status": "Open",
                  "severity": "Medium",
                  "description": "Un atacante puede invocar endpoints repetidamente o con payloads costosos.",
                  "mitigation": "Rate limiting, timeouts, límites de payload y monitoreo de métricas.",
                  "threatId": "dfa8448b-783c-4d73-88dc-44222b28b540",
                  "id": "cd9cca99-2c17-45d5-b18a-b60e928841da"
                }
              ],
              "hasOpenThreats": true
            }
